NODE_ENV=development
LOG_LEVEL=info

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=commerce_platform

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=commerce-platform
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_bff_client_id
AUTH0_CLIENT_SECRET=your_bff_client_secret
AUTH0_AUDIENCE=https://api.example.local
AUTH0_REDIRECT_URI=http://localhost:3000/auth/callback
AUTH0_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
AUTH0_SCOPE=openid profile email offline_access

SESSION_COOKIE_NAME=app_session
SESSION_COOKIE_DOMAIN=localhost
SESSION_SECRET=replace-with-32-bytes-minimum
REFRESH_TOKEN_ENCRYPTION_KEY=replace-with-32-bytes-minimum
CSRF_COOKIE_NAME=app_csrf

BFF_PORT=3000
API_GATEWAY_PORT=4000
ORDER_SERVICE_PORT=4101
INVENTORY_SERVICE_PORT=4102
PAYMENT_SERVICE_PORT=4103

ORDER_SERVICE_URL=http://localhost:4101
INVENTORY_SERVICE_URL=http://localhost:4102
PAYMENT_SERVICE_URL=http://localhost:4103
API_GATEWAY_URL=http://localhost:4000

ACCESS_TOKEN_REFRESH_WINDOW_SECONDS=120
HTTP_TIMEOUT_MS=5000

GLOBAL_RATE_LIMIT_MAX=300
GLOBAL_RATE_LIMIT_WINDOW=1 minute
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW=1 minute
ORDER_RATE_LIMIT_MAX=60
ORDER_RATE_LIMIT_WINDOW=1 minute
REPORT_RATE_LIMIT_MAX=120
REPORT_RATE_LIMIT_WINDOW=1 minute

CIRCUIT_BREAKER_TIMEOUT_MS=4000
CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=50
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=15000
